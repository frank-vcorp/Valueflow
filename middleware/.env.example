# Credencial Firebird de solo lectura
FIREBIRD_PASSWORD=<password_solo_lectura>

# UI local (generar hash: node -e "console.log(require('bcryptjs').hashSync('cambie-esta-clave', 12))")
UI_PORT=4567
UI_USERNAME=admin
UI_PASSWORD_HASH=<bcrypt_hash>

# Logging
LOG_LEVEL=info
LOG_DIR=C:/apps/siemens-middleware/logs

# Opcional: ruta absoluta a config.json
# CONFIG_PATH=C:/apps/siemens-middleware/config.json

# Opcional: ruta explícita a fbclient.dll de SAE 10
# FIREBIRD_CLIENT_LIBRARY=C:/Program Files/Firebird/Firebird_5_0/fbclient.dll
